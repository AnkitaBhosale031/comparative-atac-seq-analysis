cff-version: 1.2.0
title: "Comparative ATAC-seq Analysis of Alzheimer's Disease and Medulloblastoma Microglia"
message: "If you use this repository, please cite it as follows."
type: software

authors:
  - family-names: "Bhosale"
    given-names: "Ankita"
